{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "types/**/*.ts",
    "adapters/**/*.mjs",
    "scripts/**/*.mjs",
    "tools/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "data",
    "journal"
  ]
}
