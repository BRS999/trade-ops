# Trade Ops — environment variables template
# Copy to .env and fill in your keys.

# Paid data providers
MASSIVE_API_KEY=your_massive_api_key_here
FRED_API_KEY=your_fred_api_key_here
FMP_API_KEY=your_fmp_api_key_here
EIA_API_KEY=your_eia_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Optional — CoinGecko works without a key but is rate-limited on the public tier
# COINGECKO_API_KEY=your_coingecko_demo_key_here
# COINGECKO_PLAN=pro

# Optional environment overrides
# DEXSCREENER_BASE_URL=https://api.dexscreener.com
# DEXSCREENER_TIMEOUT_MS=15000
# BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
# BINANCE_FUTURES_TIMEOUT_MS=15000
# HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
# HYPERLIQUID_TIMEOUT_MS=15000
# DERIBIT_BASE_URL=https://www.deribit.com/api/v2
# DERIBIT_TIMEOUT_MS=15000
# COINBASE_BASE_URL=https://api.coinbase.com/api/v3/brokerage
# COINBASE_TIMEOUT_MS=15000
# KRAKEN_BASE_URL=https://api.kraken.com/0
# KRAKEN_TIMEOUT_MS=15000
# POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
# POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
# POLYMARKET_TIMEOUT_MS=15000
# DEFILLAMA_BASE_URL=https://api.llama.fi
# DEFILLAMA_COINS_BASE_URL=https://coins.llama.fi
# DEFILLAMA_STABLECOINS_BASE_URL=https://stablecoins.llama.fi
# DEFILLAMA_YIELDS_BASE_URL=https://yields.llama.fi
# DEFILLAMA_TIMEOUT_MS=15000
# BLS_API_KEY=optional_bls_registration_key
# BLS_BASE_URL=https://api.bls.gov/publicAPI/v2
# BLS_TIMEOUT_MS=15000
# FISCALDATA_BASE_URL=https://api.fiscaldata.treasury.gov/services/api/fiscal_service
# FISCALDATA_TRANSPARENCY_BASE_URL=https://www.transparency.treasury.gov/services/api/fiscal_service
# FISCALDATA_TIMEOUT_MS=15000
# CFTC_TIMEOUT_MS=20000
# GDELT_BASE_URL=https://api.gdeltproject.org/api/v2
# GDELT_TIMEOUT_MS=60000
# GDELT_MIN_INTERVAL_MS=5000
# GDELT_DEBUG=1
